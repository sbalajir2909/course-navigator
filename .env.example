# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=your-supabase-url-here
SUPABASE_SERVICE_KEY=your-supabase-service-key-here

# ── Ollama (primary LLM provider) ─────────────────────────────────────────────
# Port 11435 = Gautschi GPU node via SSH tunnel (scripts/gautschi_tunnel.sh)
# Port 11434 = local Ollama on this machine
OLLAMA_BASE_URL=http://localhost:11435/v1

# Models pulled on Gautschi / local:
#   ollama pull llama3.1:8b     (teach / course / assessment / grading / faithfulness)
#   ollama pull qwen2.5:72b     (validation)
#   ollama pull bge-m3          (embeddings)

# ── OpenAI (fallback only — used when Ollama is unreachable) ──────────────────
OPENAI_API_KEY=your-openai-key-here

# ── Other ─────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-key-here
