# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=your-supabase-url-here
SUPABASE_SERVICE_KEY=your-supabase-service-key-here

# ── Ollama (self-hosted — primary LLM provider) ───────────────────────────────
# Local Mac Ollama (default port, always tried first)
OLLAMA_LOCAL_URL=http://localhost:11434
# Gautschi GPU cluster via SSH tunnel (run scripts/gautschi_tunnel.sh first)
# OLLAMA_REMOTE_URL=http://localhost:11435

# ── Cloudflare Workers AI (fallback if Ollama unavailable) ───────────────────
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# ── OpenAI (last-resort fallback only) ───────────────────────────────────────
OPENAI_API_KEY=your-openai-key-here

# ── Other ─────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-key-here
